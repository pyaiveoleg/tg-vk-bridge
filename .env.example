# ===== Telegram (userbot — ТВОЙ личный аккаунт) =====
# Получить на https://my.telegram.org -> API development tools
TG_API_ID=1234567
TG_API_HASH=0123456789abcdef0123456789abcdef
# Строка сессии: получить командой `python login.py` (один раз)
TG_SESSION=

# ===== VK (бот-сообщество) =====
# Управление сообществом -> Работа с API -> создать ключ доступа
# со scope: messages, photos, docs
VK_TOKEN=vk1.a.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Числовой id сообщества (видно в адресе vk.com/club12345678 -> 12345678)
VK_GROUP_ID=12345678
# Твой личный VK user id (vk.com/id12345 -> 12345). Куда слать и от кого принимать ответы.
VK_OWNER_ID=12345

# ===== Поведение =====
# Пересылать ли групповые чаты/каналы Telegram (по умолчанию только личные ЛС)
FORWARD_GROUPS=false
# Белый список диалогов (опционально). Если задан — обрабатываются ТОЛЬКО эти чаты;
# если пусто — все. Через запятую/пробел. Можно id и @username, напр.:
# TG_WHITELIST=123456789, @durov, -1001234567890
TG_WHITELIST=
# Запрашивать реакции у Telegram явно. Это устраняет задержку обновлений,
# которая на некоторых аккаунтах исчезает только после открытия приложения.
REACTION_POLL_INTERVAL=10
REACTION_POLL_MESSAGES=50
# Синхронизация доступных платформам read/typing-событий.
SYNC_READS=true
READ_POLL_INTERVAL=3
SYNC_TYPING=true
# Максимальный размер скачиваемого по ссылке VK-видео.
VK_VIDEO_MAX_MB=200
# Каталог для store.json (в Docker монтируется на volume)
DATA_DIR=.
